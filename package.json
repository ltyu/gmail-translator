{
  "name": "gmail-translator",
  "version": "1.0.0",
  "description": "Auto-translate English Gmail emails to Simplified Chinese using Claude",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node20 --outfile=dist/handler.mjs --format=esm --external:@aws-sdk",
    "setup": "npx tsx setup-gmail-token.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "googleapis": "^144.0.0",
    "html-to-text": "^9.0.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/html-to-text": "^9.0.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
