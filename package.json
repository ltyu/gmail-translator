{
  "name": "gmail-translator",
  "version": "1.0.0",
  "description": "Auto-translate English Gmail emails to Simplified Chinese using Claude",
  "packageManager": "pnpm@10.4.1",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node20 --outfile=dist/handler.mjs --format=esm --external:@aws-sdk",
    "lint": "eslint \"src/**/*.ts\" \"*.ts\"",
    "setup": "tsx setup-gmail-token.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "secrets:scan": "gitleaks git --redact --no-banner",
    "secrets:scan:changes": "gitleaks git --pre-commit --redact --no-banner",
    "secrets:scan:staged": "gitleaks git --staged --redact --no-banner",
    "prepare": "node --input-type=module -e \"try { const { default: husky } = await import('husky'); husky(); } catch (error) { if (error && error.code !== 'ERR_MODULE_NOT_FOUND' && error.code !== 'MODULE_NOT_FOUND') throw error; }\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-kms": "^3.1010.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "esbuild": "^0.24.2",
    "googleapis": "^144.0.0",
    "html-to-text": "^9.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/html-to-text": "^9.0.4",
    "eslint": "^9.22.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
